{
  "expo": {
    "name": "TestGen",
    "slug": "testgen-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "testgen",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.testgen.mobile",
      "infoPlist": {
        "UIScrollViewContentInsetAdjustmentBehavior": "automatic",
        "UIViewControllerBasedStatusBarAppearance": true,
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock TestGen"
      }
    },
    "android": {
      "package": "org.testgen.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#2360E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      "expo-document-picker",
      "expo-font",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow TestGen to use Face ID to verify your identity"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
